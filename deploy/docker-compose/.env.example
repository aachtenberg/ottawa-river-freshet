# Database
POSTGRES_DB=freshet
POSTGRES_USER=freshet
POSTGRES_PASSWORD=change-me-strong-password

# Dashboard host port
DASHBOARD_PORT=8080

# ---------------------------------------------------------------------------
# River-history (Vigilance) ingester
# ---------------------------------------------------------------------------
# Comma-separated Vigilance station IDs. Default = full Ottawa River corridor
# (main stem + Gatineau cascade 442/994/982/983 + Lièvre cascade 522/196/211/300).
STATION_IDS=1195,1004,951,545,1279,984,548,550,981,1264,442,994,982,983,522,196,211,300

# Optional: KiWIS stations as "stationId:kiwisTsId:Label". Empty disables MVCA.
MVCA_STATIONS=
MVCA_LOOKBACK_HOURS=24

# ---------------------------------------------------------------------------
# Hydro-Québec open-data ingester
# ---------------------------------------------------------------------------
# Bounding box for the basin filter. Default = Ottawa basin window.
HQ_LAT_MIN=45.0
HQ_LAT_MAX=48.0
HQ_LON_MIN=-80.0
HQ_LON_MAX=-74.0

# ---------------------------------------------------------------------------
# WSC realtime hydrometric ingester
# ---------------------------------------------------------------------------
# Comma-separated WSC alphanumeric station codes. Empty = use the script's
# defaults (Britannia, Mattawa, Mississippi, Rideau, Masson-Angers, etc.).
WSC_STATIONS=
WSC_LOOKBACK_HOURS=24

# ---------------------------------------------------------------------------
# ECCC daily-climate ingester
# ---------------------------------------------------------------------------
# Pull current year + N prior years (covers prior-year tail of provisional data).
ECCC_YEARS_BACK=1

# ---------------------------------------------------------------------------
# Alerter (ntfy)
# ---------------------------------------------------------------------------
# Set NTFY_TOPIC to your own private topic — anyone subscribed sees alerts.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=change-me-private-topic
ALERTER_STATION_ID=1195
