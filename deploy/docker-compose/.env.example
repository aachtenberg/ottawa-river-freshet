# Database
POSTGRES_DB=freshet
POSTGRES_USER=freshet
POSTGRES_PASSWORD=change-me-strong-password

# Dashboard host port
DASHBOARD_PORT=8080

# Comma-separated Vigilance station IDs to ingest (default: full Ottawa River
# corridor as configured in the upstream dashboard).
STATION_IDS=1195,1004,951,545,1279,984,548,550,981,1264

# Optional: KiWIS stations on the format "stationId:kiwisTsId:Label"
# Leave empty to skip MVCA ingestion.
MVCA_STATIONS=
MVCA_LOOKBACK_HOURS=24

# Alerter — set NTFY_TOPIC to your own private topic.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=change-me-private-topic
ALERTER_STATION_ID=1195
